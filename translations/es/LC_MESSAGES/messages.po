msgstr "peor escenario entre el 5% final de las simulaciones"

#: templates/montecarlo.html:141
msgid "Giallo"
msgstr "Amarillo"

#: templates/montecarlo.html:141
#, no-python-format
msgid "scenario migliore tra il 5% finale delle simulazioni"
msgstr "mejor escenario entre el 5% final de las simulaciones"

#: templates/montecarlo.html:142
msgid "Grigio"
msgstr "Gris"

#: templates/montecarlo.html:142
msgid "campione di simulazioni casuali usate come nuvola statistica"
